# Umgebungsvariablen der Root-Layout-Variante (config.settings.prod)

# ---- Django ---------------------------------------------------------------
DJANGO_SECRET_KEY=bitte-durch-langen-zufallswert-ersetzen
DJANGO_ALLOWED_HOSTS=abfuhr.example.org
DJANGO_CSRF_TRUSTED_ORIGINS=https://abfuhr.example.org
SITE_BASE_URL=https://abfuhr.example.org
SECURE_SSL_REDIRECT=true

# ---- Betreiber (Impressum) --------------------------------------------------
OPERATOR_NAME=
OPERATOR_ADDRESS=
OPERATOR_EMAIL=

# ---- Datenbank (PostgreSQL) -------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=abfuhrkalender
POSTGRES_USER=abfuhrkalender
POSTGRES_PASSWORD=bitte-aendern

# ---- Cache (optional, empfohlen bei mehreren Workern) -----------------------
# REDIS_URL=redis://redis:6379/0

# ---- E-Mail -----------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=abfuhrkalender@example.org
ADMIN_EMAILS=admin@example.org

# ---- Sicherheit ---------------------------------------------------------------
# TOTP-Zwei-Faktor-Pflicht für /admin (django-otp). Vor Aktivierung ein Gerät
# unter /admin/otp_totp/totpdevice/ anlegen!
ADMIN_OTP_REQUIRED=false

# ---- Statistik / Datenschutz ---------------------------------------------------
ANALYTICS_ENABLED=true
ANALYTICS_RAW_RETENTION_DAYS=90

# ---- Community-Modus (§22/§24, standardmäßig aus) -------------------------------
COMMUNITY_MODE_ENABLED=false
COMMUNITY_AUTO_PUBLISH=false

# SEO (optional)
GOOGLE_SITE_VERIFICATION=
INDEXNOW_KEY=
